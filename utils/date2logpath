#!/bin/bash
# ==============================================================================
# date2logpath — 日付指定を rx.log アーカイブのパスに変換する
#
# 使用法:
#   date2logpath <日付> [ベースディレクトリ]
#
# 出力（2行）:
#   1行目: 指定日のログパス
#   2行目: 指定日の日付（20260702形式、ファイル名用）
#
# 例:
#   date2logpath 20260702
#   → /data1/uecs-data-pool/2026/07/rx.log.20260702.gz
#     20260702
#
#   # 変数に受け取る
#   read LOG_PATH DATE < <(date2logpath 20260702)
#   zgrep 192.168.120.193 "$LOG_PATH" | grep cnd | \
#       uecs_xml2csv cnd 7 4 5 29 192.168.120.193 > m304s08/cnd${DATE}.csv
#
#   # 月またぎ: date2logpath 20260801
#   → /data1/uecs-data-pool/2026/08/rx.log.20260801.gz
#     20260801
# ==============================================================================

BASE_DIR="${2:-/data1/uecs-data-pool}"
DATE_STR="$1"

if [ -z "$DATE_STR" ]; then
  echo "使用法: $0 <日付> [ベースディレクトリ]" >&2
  echo "  日付例: 20260702 / 2026-07-02 / 2026-7-2 / 2026/07/02" >&2
  exit 1
fi

# / を - に統一
NORMALIZED=$(echo "$DATE_STR" | tr '/' '-')

# 8桁（20260702）は YYYY-MM-DD に変換
if [[ "$NORMALIZED" =~ ^[0-9]{8}$ ]]; then
  NORMALIZED="${NORMALIZED:0:4}-${NORMALIZED:4:2}-${NORMALIZED:6:2}"
fi

# date コマンドで正規化
PARSED=$(date -d "$NORMALIZED" "+%Y%m%d" 2>/dev/null)
if [ -z "$PARSED" ]; then
  echo "エラー: 日付の形式が不正です: $DATE_STR" >&2
  exit 1
fi

# 前日
PARSED_PREV=$(date -d "${PARSED:0:4}-${PARSED:4:2}-${PARSED:6:2} -1 day" "+%Y%m%d")

# パス生成
make_path() {
  local D="$1"
  echo "${BASE_DIR}/${D:0:4}/${D:4:2}/rx.log.${D}.gz"
}

make_path "$PARSED"
echo "$PARSED_PREV"
